NODE_ENV=development
PORT=3001

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=user_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — production lấy từ AWS Secrets Manager, KHÔNG hardcode
JWT_ACCESS_SECRET=dev_access_secret_change_in_prod
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_prod
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# AWS (LocalStack khi local)
AWS_REGION=ap-southeast-1
AWS_ENDPOINT=http://localhost:4566
SNS_USER_TOPIC_ARN=arn:aws:sns:ap-southeast-1:000000000000:user-events

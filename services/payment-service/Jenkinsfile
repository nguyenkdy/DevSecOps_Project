pipeline {
  agent any

  environment {
    SERVICE_NAME   = 'payment-service'
    SERVICE_DIR    = 'services/payment-service'
    AWS_ACCOUNT_ID = credentials('aws-account-id')
    AWS_REGION     = 'ap-southeast-1'
    ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    IMAGE_TAG      = "${BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
  }

  options {
    timeout(time: 20, unit: 'MINUTES')
    disableConcurrentBuilds()
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Install') {
      steps {
        dir(env.SERVICE_DIR) {
          sh 'npm ci --prefer-offline --no-audit'
        }
      }
    }

    stage('Lint & Build') {
      parallel {
        stage('ESLint') {
          steps {
            dir(env.SERVICE_DIR) { sh 'npm run lint' }
          }
        }
        stage('Build') {
          steps {
            dir(env.SERVICE_DIR) { sh 'npm run build' }
          }
        }
      }
    }

    stage('Unit Test') {
      steps {
        dir(env.SERVICE_DIR) {
          sh 'npm run test:cov -- --ci --forceExit'
        }
      }
      post {
        always {
          publishHTML(target: [
            allowMissing: true,
            reportDir: "${env.SERVICE_DIR}/coverage/lcov-report",
            reportFiles: 'index.html',
            reportName: 'Payment Service Coverage'
          ])
        }
      }
    }

    stage('SonarQube') {
      steps {
        dir(env.SERVICE_DIR) {
          withSonarQubeEnv('SonarQube') {
            sh '''
              npx sonar-scanner \
                -Dsonar.projectKey=payment-service \
                -Dsonar.sources=src \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                -Dsonar.exclusions=**/*.spec.ts,**/*.module.ts
            '''
          }
        }
      }
    }

    stage('Security Scan - Trivy') {
      steps {
        sh '''
          docker build -t ${SERVICE_NAME}:scan --target production ${SERVICE_DIR}
          trivy image --severity HIGH,CRITICAL --exit-code 0 --format table ${SERVICE_NAME}:scan
          docker rmi ${SERVICE_NAME}:scan || true
        '''
      }
    }

    stage('Build & Push ECR') {
      when { branch 'main' }
      steps {
        sh '''
          aws ecr get-login-password --region ${AWS_REGION} | \
            docker login --username AWS --password-stdin ${ECR_REGISTRY}

          docker build -t ${ECR_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
            --target production ${SERVICE_DIR}
          docker tag ${ECR_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
            ${ECR_REGISTRY}/${SERVICE_NAME}:latest

          docker push ${ECR_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG}
          docker push ${ECR_REGISTRY}/${SERVICE_NAME}:latest
        '''
      }
    }

    stage('Update GitOps Manifest') {
      when { branch 'main' }
      steps {
        sh '''
          sed -i "s|tag:.*|tag: ${IMAGE_TAG}|" infra/k8s/payment-service/values.yaml
          git config user.email "ci@jenkins"
          git config user.name "Jenkins CI"
          git commit -am "ci: update payment-service to ${IMAGE_TAG}" || echo "no changes"
          git push origin main
        '''
      }
    }
  }

  post {
    success { echo "Pipeline thành công: ${SERVICE_NAME}:${IMAGE_TAG}" }
    failure { echo "Pipeline thất bại — kiểm tra log" }
    always  { sh 'docker image prune -f || true' }
  }
}

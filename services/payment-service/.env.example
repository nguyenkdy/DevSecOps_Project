NODE_ENV=development
PORT=3004

# Database (payment_db)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=payment_db

# AWS (LocalStack in dev, real AWS in prod)
AWS_REGION=ap-southeast-1
AWS_ENDPOINT=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SQS - subscribe to order-created queue
SQS_QUEUE_URL=http://localhost:4566/000000000000/order-created

# SNS - publish order.paid event
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:000000000000:order-events

# Demo VNPay settings (fake)
VNPAY_SANDBOX=true
VNPAY_MERCHANT_ID=DEMO123
VNPAY_HASH_SECRET=DEMOSECRET123
VNPAY_RETURN_URL=http://localhost:3005/payment-callback

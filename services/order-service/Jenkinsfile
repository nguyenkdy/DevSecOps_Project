pipeline {
  agent any

  environment {
    SERVICE_NAME          = 'order-service'
    SERVICE_DIR           = 'services/order-service'
    AWS_ACCOUNT_ID        = credentials('aws-account-id')
    AWS_REGION            = 'ap-southeast-1'
    ECR_REGISTRY          = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
    IMAGE_TAG             = "${BUILD_NUMBER}-${env.GIT_COMMIT?.take(7) ?: 'latest'}"
  }

  options {
    timeout(time: 20, unit: 'MINUTES')
    disableConcurrentBuilds()
  }

  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Detect Changes') {
      steps {
        script {
          def prev = env.GIT_PREVIOUS_COMMIT
          if (!prev) {
            echo "Không có previous commit — build toàn bộ"
            return
          }
          def changed = sh(
            script: "git diff --name-only ${prev} ${env.GIT_COMMIT} | grep '^${env.SERVICE_DIR}/' || true",
            returnStdout: true
          ).trim()
          if (!changed) {
            echo "Không có thay đổi trong ${env.SERVICE_DIR} — bỏ qua pipeline"
            env.SKIP = 'true'
          }
        }
      }
    }

    stage('Install') {
      when { not { environment name: 'SKIP', value: 'true' } }
      steps {
        dir(env.SERVICE_DIR) {
          sh 'npm ci --legacy-peer-deps --prefer-offline --no-audit'
        }
      }
    }

    stage('Lint & Build') {
      when { not { environment name: 'SKIP', value: 'true' } }
      parallel {
        stage('ESLint') {
          steps {
            dir(env.SERVICE_DIR) { sh 'npm run lint' }
          }
        }
        stage('Build') {
          steps {
            dir(env.SERVICE_DIR) { sh 'npm run build' }
          }
        }
      }
    }

    stage('Unit Test') {
      when { not { environment name: 'SKIP', value: 'true' } }
      steps {
        dir(env.SERVICE_DIR) {
          sh 'npm run test:cov -- --ci --forceExit'
        }
      }
    }

    stage('SonarQube') {
      when { not { environment name: 'SKIP', value: 'true' } }
      steps {
        dir(env.SERVICE_DIR) {
          withSonarQubeEnv('SonarQube') {
            sh '''
              npx sonar-scanner \
                -Dsonar.projectKey=order-service \
                -Dsonar.sources=src \
                -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                -Dsonar.exclusions=**/*.spec.ts,**/*.module.ts
            '''
          }
        }
      }
    }

    stage('Security Scan - Trivy') {
      when { not { environment name: 'SKIP', value: 'true' } }
      steps {
        sh '''
          docker build -t ${SERVICE_NAME}:scan --target production ${SERVICE_DIR}
          trivy image --severity HIGH,CRITICAL --exit-code 0 --format table ${SERVICE_NAME}:scan
          docker rmi ${SERVICE_NAME}:scan || true
        '''
      }
    }

    stage('Build & Push ECR') {
      when {
        allOf {
          expression { env.GIT_BRANCH ==~ /.*\/main|^main$/ }
          not { environment name: 'SKIP', value: 'true' }
        }
      }
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-credentials',
          accessKeyVariable: 'AWS_ACCESS_KEY_ID',
          secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
        ]]) {
          sh '''
            aws ecr get-login-password --region ${AWS_REGION} | \
              docker login --username AWS --password-stdin ${ECR_REGISTRY}

            docker build -t ${ECR_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
              --target production ${SERVICE_DIR}
            docker tag ${ECR_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG} \
              ${ECR_REGISTRY}/${SERVICE_NAME}:latest

            docker push ${ECR_REGISTRY}/${SERVICE_NAME}:${IMAGE_TAG}
            docker push ${ECR_REGISTRY}/${SERVICE_NAME}:latest
          '''
        }
      }
    }

    stage('Update GitOps Manifest') {
      when {
        allOf {
          expression { env.GIT_BRANCH ==~ /.*\/main|^main$/ }
          not { environment name: 'SKIP', value: 'true' }
        }
      }
      steps {
        sh '''
          sed -i "s|tag:.*|tag: ${IMAGE_TAG}|" infra/k8s/order-service/values.yaml
          git config user.email "ci@jenkins"
          git config user.name "Jenkins CI"
          git commit -am "ci: update order-service to ${IMAGE_TAG}" || echo "no changes"
          git push origin main
        '''
      }
    }
  }

  post {
    always {
      script {
        if (env.SKIP == 'true') {
          currentBuild.result = 'NOT_BUILT'
          echo "Pipeline skipped — no changes in ${env.SERVICE_DIR}"
        }
      }
      sh 'docker image prune -f || true'
    }
    success { echo "Pipeline thành công: ${SERVICE_NAME}:${IMAGE_TAG}" }
    failure { echo "Pipeline thất bại — kiểm tra log" }
  }
}
